# -----------------------------------------------
# EarnStack Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# -----------------------------------------------

# ── Frontend (set in Vercel project settings) ──
VITE_API_URL=https://api.earnstack.ca

# ── Backend (set in Railway project settings) ──

# Server
PORT=3001

# Origin allowed by CORS (your Vercel frontend URL)
APP_ORIGIN=https://earnstack.ca

# JWT
JWT_SECRET=change_me_use_a_long_random_string

# Database (SQLite path for local dev; update for production volume)
DATABASE_URL=./data/earnstack.db

# Email (Resend)
RESEND_API_KEY=re_change_me
EMAIL_FROM=noreply@earnstack.ca

# PayPal Payouts
PAYPAL_CLIENT_ID=change_me
PAYPAL_CLIENT_SECRET=change_me
PAYPAL_ENV=sandbox
# Set PAYPAL_ENV=live for production

# Offer Wall Networks
THEOREMREACH_API_KEY=change_me
ADGATE_API_KEY=change_me
CPAGRIP_POSTBACK_SECRET=change_me
